{
  "name": "@borgar/zip",
  "version": "1.0.0",
  "description": "A library to manipulate zip files, using native implementations for compression where available.",
  "type": "module",
  "source": "src/index.ts",
  "main": "dist/index.cjs",
  "types": "dist/index.d.cts",
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.cts",
      "default": "./dist/index.js"
    }
  },
  "license": "MIT",
  "author": "Borgar Þorsteinsson <borgar@borgar.net> (http://borgar.net/)",
  "scripts": {
    "build": "tsdown",
    "lint": "eslint *.js src/",
    "typecheck": "tsc --noEmit",
    "docs": "typedoc && concat-md tempdocs > API.md && rm -rf tempdocs",
    "test": "vitest run",
    "check": "npm run test && npm run lint && npm run typecheck",
    "release": "git diff --exit-code && tsup && npm publish && V=$(jq -r .version package.json) && git tag -a $V -m $V && git push origin $V && gh release create $V --generate-notes"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "tsdown": {
    "entry": "src/index.ts",
    "format": "esm",
    "platform": "neutral",
    "sourcemap": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/borgar/zip.git"
  },
  "bugs": {
    "url": "https://github.com/borgar/zip/issues"
  },
  "keywords": [
    "zip",
    "deflate",
    "inflate",
    "archive"
  ],
  "dependencies": {
    "uzip": "~0.20201231.0"
  },
  "devDependencies": {
    "@borgar/eslint-config": "~4.1.0",
    "@eslint/js": "~10.0.1",
    "@types/node": "~25.6.0",
    "@types/pako": "~2.0.4",
    "@types/uzip": "~0.20201231.2",
    "concat-md": "~0.5.1",
    "eslint": "~10.2.1",
    "globals": "~17.5.0",
    "tsdown": "~0.21.10",
    "typedoc": "~0.28.19",
    "typedoc-plugin-markdown": "~4.11.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "~8.59.1",
    "vitest": "~4.1.5"
  }
}
